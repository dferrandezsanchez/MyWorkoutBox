// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.VarChar(36)
  name         String   @db.VarChar(191)
  email        String   @unique @db.VarChar(191)
  passwordHash String   @db.VarChar(191)
  role         String   @db.VarChar(32)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  performances PerformanceRecord[]
  auditLogs    AuditLog[]
  memberships  UserTenantMembership[]

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @db.VarChar(191)
  slug      String   @unique @db.VarChar(191)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants Tenant[]

  @@map("organizations")
}

model Tenant {
  id             String   @id @default(uuid()) @db.VarChar(36)
  organizationId String   @db.VarChar(36)
  name           String   @db.VarChar(191)
  slug           String   @unique @db.VarChar(191)
  appName        String   @db.VarChar(191)
  shortName      String   @db.VarChar(191)
  mark           String   @db.VarChar(16)
  claim          String   @db.VarChar(191)
  description    String   @db.Text
  primary        String   @db.VarChar(7)
  primaryHover   String   @db.VarChar(7)
  primarySoft    String   @db.VarChar(7)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  memberships  UserTenantMembership[]
  clients      Client[]
  exercises    Exercise[]
  performances PerformanceRecord[]
  auditLogs    AuditLog[]

  @@index([organizationId])
  @@map("tenants")
}

model UserTenantMembership {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  tenantId  String   @db.VarChar(36)
  role      String   @db.VarChar(32)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId, role])
  @@map("user_tenant_memberships")
}

model Client {
  id                String    @id @default(uuid()) @db.VarChar(36)
  tenantId          String    @db.VarChar(36)
  firstName         String    @db.VarChar(191)
  lastName          String    @db.VarChar(191)
  birthDate         DateTime
  height            Float?
  weight            Float?
  bodyFatPercentage Float?
  notes             String?   @db.Text
  status            String    @default("ACTIVE") @db.VarChar(32)
  anonymizedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  performances PerformanceRecord[]

  @@index([tenantId, status])
  @@map("clients")
}

model Exercise {
  id                   String          @id @default(uuid()) @db.VarChar(36)
  tenantId             String          @db.VarChar(36)
  name                 String          @db.VarChar(191)
  category             String          @db.VarChar(64)
  movementPattern      String          @default("general") @db.VarChar(64)
  evaluationType       String          @default("repetitions") @db.VarChar(64)
  improvementDirection String          @default("higher") @db.VarChar(32)
  defaultUnit          String          @db.VarChar(32)
  measurementFields    String          @db.Text
  variantGroups        String          @db.Text
  description          String?         @db.Text
  status               String          @default("ACTIVE") @db.VarChar(32)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  performances PerformanceRecord[]

  @@index([tenantId, status])
  @@map("exercises")
}

model PerformanceRecord {
  id          String          @id @default(uuid()) @db.VarChar(36)
  tenantId    String          @db.VarChar(36)
  clientId    String          @db.VarChar(36)
  exerciseId  String          @db.VarChar(36)
  trainerId   String          @db.VarChar(36)
  value       String          @db.VarChar(191)
  unit        String          @db.VarChar(32)
  weight      Float?
  repetitions Int?
  duration    Float?
  distance    Float?
  date        DateTime
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  client   Client   @relation(fields: [clientId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])
  trainer  User     @relation(fields: [trainerId], references: [id])

  @@index([tenantId, clientId])
  @@index([clientId, exerciseId, date(sort: Desc)])
  @@map("performance_records")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.VarChar(36)
  tenantId   String   @db.VarChar(36)
  userId     String   @db.VarChar(36)
  action     String   @db.VarChar(64)
  entityType String   @db.VarChar(64)
  entityId   String   @db.VarChar(36)
  metadata   String?  @db.Text
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}
