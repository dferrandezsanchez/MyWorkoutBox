COMPOSE_PROJECT_NAME=myworkoutbox
IMAGE_TAG=local
APP_PORT=8080

MARIADB_DATABASE=myworkoutbox
MARIADB_USER=myworkoutbox
MARIADB_PASSWORD=local-database-password
MARIADB_ROOT_PASSWORD=local-root-password
DATABASE_URL=mysql://myworkoutbox:local-database-password@database:3306/myworkoutbox

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:8080
VITE_TENANT_ID=platform
