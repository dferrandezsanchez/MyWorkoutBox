{
  "name": "control-marcas-frontend",
  "version": "1.0.0",
  "description": "Frontend SPA para el sistema de control de marcas de entrenamiento",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage --coverage.thresholds.functions 95",
    "lint": "eslint .",
    "quality": "npm run lint && npm run test:coverage && npm run build && npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@tanstack/react-query": "5.59.20",
    "autoprefixer": "10.4.20",
    "axios": "^1.18.1",
    "lucide-react": "^1.17.0",
    "postcss": "^8.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "3.4.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^16.5.0",
    "jsdom": "25.0.1",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
